+    const email = requiredString(req.body, "email");
+    const accessToken = requiredString(req.body, "access_token");
+    const refreshToken = requiredString(req.body, "refresh_token");
+    const explicitExpiry =
+      normalizeExpiryISO(requiredString(req.body, "expired")) ||
+      normalizeExpiryISO(requiredString(req.body, "expires_at"));
+    const expiresAt = explicitExpiry || inferExpiryISO(accessToken);
+
+    if (!email || !email.includes("@")) {
+      res.status(400).json({ error: { message: "email is required" } });
+      return;
+    }
+    if (!accessToken) {
+      res.status(400).json({ error: { message: "access_token is required" } });
+      return;
+    }
+    if (!refreshToken) {
+      res.status(400).json({ error: { message: "refresh_token is required" } });
+      return;
+    }
+    if (!expiresAt) {
+      res.status(400).json({
+        error: {
+          message:
+            "expired/expires_at is required when access_token has no readable exp claim",
+        },
+      });
+      return;
+    }
+
+    const provider = registry.get("cursor");
+    const token: TokenData = {
+      accessToken,
+      refreshToken,
+      email,
+      expiresAt,
+      accountUuid:
+        optionalString(req.body, "account_uuid") ||
+        optionalString(req.body, "cursor_service_machine_id") ||
+        "",
+      provider: "cursor",
+      lastRefreshAt: new Date().toISOString(),
+      cursorServiceMachineId: optionalString(
