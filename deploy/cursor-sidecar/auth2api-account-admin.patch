+test("POST /admin/accounts/cursor provisions token without echoing secrets", async (t) => {
+  const authDir = fs.mkdtempSync(path.join(os.tmpdir(), "auth2api-smoke-"));
+  const server = await startAppWithLoadedRegistry(makeConfig(authDir));
+  t.after(async () => {
+    await stopApp(server);
+    fs.rmSync(authDir, { recursive: true, force: true });
+  });
+
+  const response = await requestJson({
+    server,
+    method: "POST",
+    path: "/admin/accounts/cursor",
+    headers: { Authorization: "Bearer test-key" },
+    body: {
+      email: "cursor-new@example.com",
+      access_token: "cursor-access-secret",
+      refresh_token: "cursor-refresh-secret",
+      expires_at: "2026-05-15T12:00:00Z",
+      account_uuid: "cursor-account-uuid",
+      cursor_service_machine_id: "cursor-machine",
+      cursor_client_version: "3.3.30",
+      cursor_membership_type: "pro",
+    },
+  });
+
+  assert.equal(response.status, 201);
+  assert.equal(response.body.provider, "cursor");
+  assert.equal(response.body.account_ref, "cursor-new@example.com");
+  assert.equal(response.body.email, "cursor-new@example.com");
+  assert.equal(response.body.cursor_client_version, "3.3.30");
+  assert.equal(JSON.stringify(response.body).includes("cursor-access-secret"), false);
+  assert.equal(JSON.stringify(response.body).includes("cursor-refresh-secret"), false);
+
+  const accounts = await requestJson({
+    server,
+    method: "GET",
+    path: "/admin/accounts",
+    headers: { Authorization: "Bearer test-key" },
+  });
+  assert.equal(accounts.status, 200);
+  assert.equal(accounts.body.providers.cursor.account_count, 1);
+  assert.equal(
+    accounts.body.providers.cursor.accounts[0].email,
+    "cursor-new@example.com",
+  );
+});
