+test("cursor text tool-call parser reads Cursor tool markers", () => {
+  const text =
+    "Checking files.\n" +
+    "<\uFF5Ctool\u2581calls\u2581begin\uFF5C><\uFF5Ctool\u2581call\u2581begin\uFF5C>\n" +
+    "Glob\n" +
+    "<\uFF5Ctool\u2581sep\uFF5C>glob_pattern\n" +
+    "AGENTS.md\n" +
+    "<\uFF5Ctool\u2581sep\uFF5C>target_directory\n" +
+    "/workspace\n" +
+    "<\uFF5Ctool\u2581call\u2581end\uFF5C><\uFF5Ctool\u2581calls\u2581end\uFF5C>";
+
+  const parsed = __parseCursorTextToolCalls(text);
+
+  assert.ok(parsed);
+  assert.equal(parsed.leadingText, "Checking files.\n");
+  assert.equal(parsed.toolCalls.length, 1);
+  assert.equal(parsed.toolCalls[0].name, "Glob");
+  assert.deepEqual(parsed.toolCalls[0].input, {
+    pattern: "AGENTS.md",
+    path: "/workspace",
+  });
