+      cursorConfigVersion: optionalString(req.body, "cursor_config_version"),
+      cursorClientId: optionalString(req.body, "cursor_client_id"),
+      cursorMembershipType: optionalString(req.body, "cursor_membership_type"),
+    };
+
+    provider.manager.addAccount(token);
+    provider.manager.startAutoRefresh();
+    provider.manager.startStatsLogger();
+
+    res.status(201).json({
+      provider: "cursor",
+      account_ref: email,
+      email,
+      expires_at: expiresAt,
+      account_uuid: token.accountUuid || undefined,
+      cursor_service_machine_id: token.cursorServiceMachineId,
