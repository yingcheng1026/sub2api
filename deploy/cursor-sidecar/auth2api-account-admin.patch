+
+const CURSOR_TOOL_MARKERS = {
+  callsBegin: ["<\uFF5Ctool\u2581calls\u2581begin\uFF5C>", "<|tool_calls_begin|>"],
+  callsEnd: ["<\uFF5Ctool\u2581calls\u2581end\uFF5C>", "<|tool_calls_end|>"],
+  callBegin: ["<\uFF5Ctool\u2581call\u2581begin\uFF5C>", "<|tool_call_begin|>"],
+  callEnd: ["<\uFF5Ctool\u2581call\u2581end\uFF5C>", "<|tool_call_end|>"],
+  sep: ["<\uFF5Ctool\u2581sep\uFF5C>", "<|tool_sep|>"],
+};
+
+function findAnyMarker(
+  text: string,
+  markers: string[],
+  fromIndex = 0,
+): { index: number; marker: string } | null {
+  let best: { index: number; marker: string } | null = null;
+  for (const marker of markers) {
+    const index = text.indexOf(marker, fromIndex);
+    if (index < 0) continue;
+    if (!best || index < best.index) best = { index, marker };
+  }
+  return best;
+}
+
+function splitByAnyMarker(text: string, markers: string[]): string[] {
+  const parts: string[] = [];
+  let pos = 0;
+  while (pos <= text.length) {
+    const found = findAnyMarker(text, markers, pos);
+    if (!found) {
+      parts.push(text.slice(pos));
+      break;
+    }
+    parts.push(text.slice(pos, found.index));
+    pos = found.index + found.marker.length;
+  }
+  return parts;
+}
+
+function coerceCursorToolValue(raw: string): unknown {
+  const trimmed = raw.trim();
+  if (!trimmed) return "";
+  if (/^[\[{"]/.test(trimmed) || /^(true|false|null|-?\d+(\.\d+)?)$/.test(trimmed)) {
+    try {
+      return JSON.parse(trimmed);
+    } catch {
+      return raw.replace(/^\s+|\s+$/g, "");
+    }
+  }
+  return raw.replace(/^\s+|\s+$/g, "");
+}
+
+function renameCursorInputKey(toolName: string, key: string): string {
+  if (toolName === "Glob") {
+    if (key === "glob_pattern") return "pattern";
+    if (key === "target_directory") return "path";
+  }
+  if (toolName === "Read") {
+    if (key === "target_file" || key === "file" || key === "path") return "file_path";
+  }
+  return key;
+}
+
+function renameCursorToolName(name: string): string {
+  if (name === "Shell" || name === "Terminal") return "Bash";
+  return name;
+}
+
+function parseCursorToolBlock(block: string): CursorTextToolCall | null {
+  const segments = splitByAnyMarker(block, CURSOR_TOOL_MARKERS.sep);
+  const header = (segments.shift() || "").trim();
+  const rawName = header.split(/\r?\n/).find((line) => line.trim())?.trim() || "";
+  if (!rawName) return null;
+  const name = renameCursorToolName(rawName);
+
+  const input: Record<string, unknown> = {};
+  for (const segment of segments) {
+    const lines = segment.replace(/^\s+/, "").split(/\r?\n/);
+    const rawKey = (lines.shift() || "").trim();
+    if (!rawKey) continue;
+    const key = renameCursorInputKey(name, rawKey);
+    input[key] = coerceCursorToolValue(lines.join("\n"));
+  }
+  return { name, input };
+}
+
+export function __parseCursorTextToolCalls(
+  text: string,
+): CursorTextToolParseResult | null {
+  const callsBegin = findAnyMarker(text, CURSOR_TOOL_MARKERS.callsBegin);
+  if (!callsBegin) return null;
+
+  const callsEnd = findAnyMarker(
+    text,
+    CURSOR_TOOL_MARKERS.callsEnd,
+    callsBegin.index + callsBegin.marker.length,
+  );
+  const leadingText = text.slice(0, callsBegin.index);
+  const innerStart = callsBegin.index + callsBegin.marker.length;
+  const innerEnd = callsEnd?.index ?? text.length;
+  const inner = text.slice(innerStart, innerEnd);
+  const trailingText = callsEnd
+    ? text.slice(callsEnd.index + callsEnd.marker.length)
+    : "";
+
+  const toolCalls: CursorTextToolCall[] = [];
+  let pos = 0;
+  while (pos < inner.length) {
+    const callBegin = findAnyMarker(inner, CURSOR_TOOL_MARKERS.callBegin, pos);
+    if (!callBegin) break;
+    const blockStart = callBegin.index + callBegin.marker.length;
+    const callEnd = findAnyMarker(inner, CURSOR_TOOL_MARKERS.callEnd, blockStart);
+    const blockEnd = callEnd?.index ?? inner.length;
+    const parsed = parseCursorToolBlock(inner.slice(blockStart, blockEnd));
+    if (parsed) toolCalls.push(parsed);
+    pos = callEnd ? callEnd.index + callEnd.marker.length : inner.length;
+  }
+
+  if (!toolCalls.length) return null;
+  return { leadingText, trailingText, toolCalls };
+}
